# Copy to .env and fill in ONE provider key. Groq is free (no credit card).
# Ingestion + semantic search work with NO key at all (embeddings run locally);
# a key is only needed for Q&A, summaries, and flashcards.

# --- Choose your LLM backend ---------------------------------------------
# "groq"   = free hosted models (recommended)
# "claude" = Anthropic Claude (requires purchased API credits)
# empty    = auto-detect from whichever key below is set (Groq preferred)
DEVVAULT_PROVIDER=groq

# Groq — free, no credit card: https://console.groq.com  ->  API Keys
GROQ_API_KEY=
# DEVVAULT_GROQ_MODEL=llama-3.3-70b-versatile

# Claude — only if your account has API credits
ANTHROPIC_API_KEY=
# DEVVAULT_MODEL=claude-opus-4-8      # or claude-haiku-4-5 (cheaper)

# --- Optional overrides ---------------------------------------------------
# DEVVAULT_DATA_DIR=./data
# DEVVAULT_TOP_K=6
# DEVVAULT_CHUNK_SIZE=1200
# DEVVAULT_CHUNK_OVERLAP=150
# DEVVAULT_MAX_DOC_CHARS=120000
